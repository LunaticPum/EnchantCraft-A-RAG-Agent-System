```java title:"题解"
class Solution {  
    public ListNode mergeKLists(ListNode[] lists) {  
        PriorityQueue<Integer> stack = new PriorityQueue<>();  
  
        for (ListNode list : lists) {  
            while (list != null) {  
                stack.add(list.val);  
                list = list.next;  
            }  
        }  
        ListNode dummy = new ListNode();  
        ListNode cur = dummy;  
  
        // 重新构建有序链表  
        while (!stack.isEmpty()) {  
  
            cur.next = new ListNode(stack.poll());  
            cur = cur.next;  
        }  
  
        return dummy.next;  
    }  
}
