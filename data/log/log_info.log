    "type" : "function",
    "function" : {
      "name" : "searchKnowledgeBase",
      "description" : "在知识库中搜索与查询关键词相关的文档内容。返回标题路径和正文片段，LLM 应基于返回的片段回答用户问题。",
      "parameters" : {
        "type" : "object",
        "properties" : {
          "query" : {
            "type" : "string"
          }
        },
        "required" : [ "query" ]
      }
    }
  } ]
