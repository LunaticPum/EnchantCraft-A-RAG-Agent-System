```java title:"题解"
class Solution {  
    public int[] maxSlidingWindow(int[] nums, int k) {  
        if (nums == null || nums.length == 0) return new int[0];  
  
        int n = nums.length;  
        int[] ans = new int[n - k + 1];  
        Deque<Integer> maxValue = new ArrayDeque<>();  
  
        for (int i = 0; i < n; i++) {  
            while (!maxValue.isEmpty() && maxValue.peek() <= i - k) {  
                maxValue.poll();  
            }  
  
            while (!maxValue.isEmpty() && nums[maxValue.peekLast()] < nums[i]) {  
                maxValue.pollLast();  
            }  
            maxValue.offerLast(i);  
  
            if (i >= k - 1) {  
                ans[i-k+1] = nums[maxValue.peek()];  
            }  
        }        
	    return ans;  
    }  
}
