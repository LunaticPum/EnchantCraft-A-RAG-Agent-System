```Java title:"题解"
class Solution {
    /**
     * 判断能否按顺序学完所有课程，本质：使用拓扑排序检测有向图中是否存在环
     * 
     * @param numCourses 课程总数
     * @param prerequisites 前置课程关系，[a, b]表示学习 a 之前必须先学习 b
     * @return 能否学完所有课程（有向图中是否存在环）
     */
    public static boolean canFinish(int numCourses, int[][] prerequisites) {
        // 每个节点的入度
        int[] indegrees = new int[numCourses];

        // 邻接表
        List<Integer>[] graph = new List[numCourses];
        // 初始化邻接表
        for (int i = 0; i < numCourses; i++) {
            graph[i] = new ArrayList<>();
        }

        // 填充初始邻接表和入度值
        for (int[] prerequisite : prerequisites) {
            // 添加从课程 prerequisite[1] 到课程 prerequisite[0] 的有向边
            graph[prerequisite[1]].add(prerequisite[0]);
            // 课程 prerequisite[0] 的入度加1
            indegrees[prerequisite[0]]++;
        }

        // 使用队列进行拓扑排序
        Queue<Integer> queue = new ArrayDeque<>();

        // 首先找到所有头部节点（入度为 0 的节点）
        for (int i = 0; i < numCourses; i++) {
            if (indegrees[i] == 0) {
                queue.add(i);
            }
        }

        // 执行拓扑排序
        while (!queue.isEmpty()) {
            // 当前节点
            int cur = queue.poll();
            // 获取当前节点的后继节点
            List<Integer> targets = graph[cur];

            // 遍历所有的后继节点，减少他们的入度
            for (int next : targets) {
                // 减少入度
                indegrees[next]--;
                // 如果后继节点的入度为0，加入队列
                if (indegrees[next] == 0) {
                    queue.add(next);
                }
            }
        }

        // 检查所有节点的入度是否都为0
        // 若存在入度不为0的节点，说明图中存在环，无法完成所有课程
        return Arrays.stream(indegrees).allMatch(p -> p == 0);
    }
}
