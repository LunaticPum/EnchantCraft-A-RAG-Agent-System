```java title:"题解"
class Solution {  
    public List<Integer> findAnagrams(String s, String p) {  
        List<Integer> ans = new ArrayList<>();  
        int m = s.length();  
        int n = p.length();  
        if (m < n) return ans;  
  
        int[] countP = new int[26];  
        for (int i = 0; i < n; i++) {  
            countP[p.charAt(i) - 'a']++;  
        }  
  
        int[] countS = new int[26];  
        for (int i = 0; i < m; i++) {  
            countS[s.charAt(i) - 'a']++;  
            if (i >= n) {  
                countS[s.charAt(i - n) - 'a']--;  
            }  
            if (i >= n - 1 && match(countS, countP)) {  
                ans.add(i - n + 1);  
            }  
        }        return ans;  
    }  
  
    public boolean match(int[] countS, int[] countP) {  
        for (int i = 0; i < 26; i++) {  
            if (countS[i] != countP[i]) return false;  
        }  
        return true;  
    }  
}
