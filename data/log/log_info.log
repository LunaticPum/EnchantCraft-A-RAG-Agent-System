```java title:"题解"
class Solution {  
    public int majorityElement(int[] nums) {  
        int n = nums.length;  
        if (n == 0) return 0;  
  
        HashMap<Integer, Integer> map = new HashMap<>();  
        for (int num : nums) {  
            map.put(num, map.getOrDefault(num, 0) + 1);  
        }  
  
        int ans = 0;  
        for (Map.Entry<Integer, Integer> entry : map.entrySet()) {  
            if (entry.getValue() > n / 2) ans = entry.getKey();  
        }  
  
        return ans;  
    }  
}
