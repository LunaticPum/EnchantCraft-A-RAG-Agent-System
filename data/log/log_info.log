```java title:"题解"
class Solution {  
    public int maxArea(int[] height) {  
        int maxTank = 0;  
        int left = 0, right = height.length - 1;  
  
        while (left <= right) {  
  
            int curHeight = Math.min(height[left], height[right]);  
            maxTank = Math.max(curHeight * (right - left), maxTank);  
            if (height[left] < height[right]) {  
                left++;  
            } else {  
  
                right--;  
            }  
        }        
        return maxTank;  
    }  
}
