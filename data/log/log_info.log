```java title:"题解"
class Solution {
    public int search(int[] nums, int target) {
        int turn = -1;
        
        for (int i = 0;i < nums.length-1;i++) {
            if (nums[i] > nums[i+1]) {
                turn = i;
                break;
            }
        }

        int left = 0, right = nums.length-1;
        if (turn != -1) {
            if (target >= nums[0]) {
                left = 0;
                right = turn;
            } else {
                left = turn +1;
                right = nums.length-1;
            }
        }

        while (left <= right) {
            int mid = left + (right - left) / 2;
            if (nums[mid] == target) {
                return mid;
            } else if (nums[mid] < target) {
                left = mid + 1;
            } else {
                right = mid -1;
            }
        }

        return -1;
    }
}
