```java title:"解法一"
class Solution {  
    public int subarraySum(int[] nums, int k) {  
        int ans = 0;  
  
        // 枚举起点  
        for (int i = 0; i < nums.length; i++) {  
  
            int sum = 0;  
  
            // 从当前位置不断向后累加  
            for (int j = i; j < nums.length; j++) {  
  
                sum += nums[j];  
  
                // 连续区间和等于 k                
                if (sum == k) {  
                    ans++;  
                }  
            }        
        }  
        return ans;  
    }  
}
```

```java title:"解法二"
class Solution {  
    public int subarraySum(int[] nums, int k) {  
        Map<Integer, Integer> map = new HashMap<>();  
  
        // 前缀和为 0 出现 1 次  
        map.put(0, 1);  
  
        int prefix = 0;  
        int ans = 0;  
  
        for (int num : nums) {  
            prefix += num;  
  
            // 查找是否存在 prefix-k            
            if (map.containsKey(prefix - k)) {  
                ans += map.get(prefix - k);  
            }  
  
            // 记录当前前缀和  
            map.put(prefix, map.getOrDefault(prefix, 0) + 1);  
        }  
  
        return ans;  
    }  
}
