```java title:"题解"
class Solution {  
    public List<Integer> findDisappearedNumbers(int[] nums) {  
        int n = nums.length;  
        int[] set = new int[n + 1];  
        List<Integer> ans = new ArrayList<>();  
  
        for (int num : nums) {  
            set[num]++;  
        }  
  
        for (int i = 1; i < set.length; i++) {  
            if (set[i] == 0) {  
                ans.add(i);  
            }  
        }  
        return ans;  
    }  
}
