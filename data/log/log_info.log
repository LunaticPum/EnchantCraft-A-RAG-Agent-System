```java title:"题解"
class Solution {  
    public int rob(int[] nums) {  
        int n = nums.length;  
        int[][] dp = new int[n][3];  
  
        dp[0][0] = nums[0];  
        dp[0][1] = 0;  
  
        for (int i = 1; i < n; i++) {  
            dp[i][0] = dp[i - 1][1] + nums[i];  
            dp[i][1] = Math.max(dp[i - 1][0], dp[i - 1][1]);  
        }  
  
        return Math.max(dp[n - 1][0], dp[n - 1][1]);  
    }  
}
