```java title:"题解"
class Solution {  
    public String longestPalindrome(String s) {  
        int n = s.length();  
        boolean[][] dp = new boolean[n][n];  
  
        int start = 0, maxLen = 1;  
  
        for (int i = n - 1; i >= 0; i--) {  
            for (int j = i; j < n; j++) {  
                if (s.charAt(i) == s.charAt(j)) {  
                    if (j - i <= 1 || dp[i + 1][j - 1]) {  
                        dp[i][j] = true;  
                        if (j - i + 1 > maxLen) {  
                            maxLen = j - i + 1;  
                            start = i;  
                        }  
                    }                
                }            
            }        
        }  
        return s.substring(start, start + maxLen);  
    }  
}
